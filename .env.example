# ── Copy this to .env.local and fill in your values ──────────────────────────
# NEVER commit .env.local to Git

# Gmail (Nodemailer)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not your real password)
STUDIO_EMAIL=hello@vibewebstudio.com     # Where inquiry emails land

# Anthropic (AI Chat Widget)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://vibewebstudio.com
